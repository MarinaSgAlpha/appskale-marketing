# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored.

# --- Resend (contact form) ---
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here

# Where form submissions get delivered.
CONTACT_TO_EMAIL=hello@appskale.ai

# Sender address on a domain you've verified in Resend.
# https://resend.com/domains
CONTACT_FROM_EMAIL=hello@appskale.ai

# Optional: comma-separated BCC list.
# CONTACT_BCC_EMAIL=founders@appskale.ai
